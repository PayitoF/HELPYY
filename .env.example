# ============================================================
# Helpyy Hand — Environment Variables
# ============================================================
# Copy to .env and customize for your environment.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Provider ---
# "local" = Ollama (Gemma 4), "bedrock" = AWS Bedrock (Claude)
LLM_PROVIDER=local
OLLAMA_MODEL=gemma4:e4b
OLLAMA_URL=http://localhost:11434
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
AWS_REGION=us-east-1

# --- ML Service ---
# Mock local server (default) or real ML API in production
ML_SERVICE_URL=http://localhost:8001
# ML_SERVICE_URL=https://ml-scoring.internal

# --- Database ---
# "sqlite" for local dev, "dynamodb" for production
DATABASE_TYPE=sqlite
SQLITE_DB_PATH=data/helpyy.db
# DYNAMODB_TABLE_PREFIX=helpyy-hand-

# --- PII Vault ---
PII_VAULT_TTL_HOURS=24

# --- Monitor Agent ---
MONITOR_INTERVAL_HOURS=6

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=DEBUG

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
